---
import { services } from '../data/services';
import SectionHeading from './SectionHeading.astro';

interface Props {
  limit?: number;
  title?: string;
  description?: string;
}

const {
  limit,
  title = 'Услуги нашего детейлинга',
  description = 'От полировки и керамики до защитной пленки и химчистки — подбираем услуги под состояние автомобиля, задачу владельца и желаемый результат.',
} = Astro.props;
const items = typeof limit === 'number' ? services.slice(0, limit) : services;
---

<section class="section">
  <div class="container">
    <SectionHeading
      label="Основные услуги"
      title={title}
      description={description}
    />
    <div class="service-grid">
      {items.map((service) => (
        <article class="surface-card service-card reveal">
          <div class="service-card-copy">
            <h3>{service.name}</h3>
            <p>{service.teaser}</p>
            <div class="service-card-meta">
              <span class="price-pill">{service.priceFrom}</span>
              <a href={`/uslugi/${service.slug}`} class="button button-inline">Подробнее</a>
            </div>
          </div>
          <div class="service-card-media">
            <img src={service.image} alt={service.name} loading="lazy" />
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
