---
interface Item {
  label: string;
  href: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs container" aria-label="Хлебные крошки">
  <ol>
    {items.map((item, index) => (
      <li>
        {index === items.length - 1 ? <span>{item.label}</span> : <a href={item.href}>{item.label}</a>}
      </li>
    ))}
  </ol>
</nav>
