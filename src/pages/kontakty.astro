---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import ContactSection from '../components/ContactSection.astro';
import LeadForm from '../components/LeadForm.astro';
import { siteConfig } from '../data/site';
---

<Layout
  title="Контакты Rush Detailing — студия детейлинга в Москве, Строгино"
  description="Контакты Rush Detailing: Москва, ул. Маршала Катукова, 24А, стр. 1, этаж -1. Каждый день с 10:00 до 21:00. Телефон, Telegram, WhatsApp, карта и запись на детейлинг."
  pagePath="/kontakty"
  image="/images/hero-kontakty.jpg"
  keywords={[
    ...siteConfig.seo.defaultKeywords,
    'контакты детейлинг москва',
    'детейлинг строгино адрес',
    'rush detailing контакты',
  ]}
  breadcrumbs={[
    { label: 'Главная', href: '/' },
    { label: 'Контакты', href: '/kontakty' },
  ]}
>
  <HeroSection
    eyebrow="Контакты"
    title="Контакты студии детейлинга Rush Detailing в Москве"
    description="Записаться и связаться с нами можно по телефону, в Telegram, WhatsApp или через форму на сайте. Студия находится в Строгино: Москва, ул. Маршала Катукова, 24А, стр. 1, этаж -1."
    image="/images/hero-kontakty.jpg"
    mobileImage="/images/hero-kontakty-mob.jpg"
    compact={true}
    mobileDim={true}
  />
  <ContactSection />
  <LeadForm compact={true} />
</Layout>
